{
  "id": "sqlite-unique",
  "name": "SQLite pushdown uniqueness workload",
  "dataset": "data/local_core.csv",
  "backend": "sqlite",
  "benchmark_class": "sql_exact",
  "exactness": "exact",
  "table_name": "customer_quality",
  "suites": ["nightly-sql", "release-ga"],
  "loader": {
    "format": "csv",
    "null_values": ["", "NULL"]
  },
  "expected": {
    "success": false,
    "issue_count": 1
  },
  "truthound": {
    "validators": ["unique"],
    "validator_config": {
      "unique": {
        "columns": ["customer_id"]
      }
    },
    "pushdown": true
  },
  "gx": {
    "expectations": [
      {
        "type": "unique",
        "column": "customer_id"
      }
    ]
  }
}

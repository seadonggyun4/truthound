  },
  "truthound": {
    "validators": ["unique"],
    "validator_config": {
      "unique": {
        "columns": ["customer_id"]
      }
    }
  },
  "gx": {
    "expectations": [
      {
        "type": "unique",
        "column": "customer_id"
      }
    ]
  }
}
